<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Payments Admin | Adalyn Technologies</title>
  <meta name="robots" content="noindex, nofollow">
  <style>
    body { font-family: -apple-system, Segoe UI, Arial, sans-serif; background: #0f172a; color: #e2e8f0; margin: 0; padding: 32px; }
    h1 { color: #fff; }
    .card { background: #1e293b; border-radius: 10px; padding: 24px; margin-bottom: 24px; }
    input, select { width: 100%; padding: 10px 12px; border-radius: 6px; border: 1px solid #334155; background: #0f172a; color: #fff; font-size: 14px; box-sizing: border-box; margin-bottom: 10px; }
    label { font-size: 12px; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.5px; }
    button { background: #d4a853; color: #0f172a; border: none; padding: 10px 20px; border-radius: 6px; font-weight: 700; cursor: pointer; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 10px 12px; text-align: left; border-bottom: 1px solid #334155; font-size: 13px; }
    th { color: #94a3b8; text-transform: uppercase; font-size: 11px; }
    .badge { padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; background: #334155; }
    #adminGate { max-width: 400px; margin: 100px auto; text-align: center; }
    #mainContent { display: none; }
    .ref-copy { cursor: pointer; color: #d4a853; }
  </style>
</head>
<body>
  <div id="adminGate">
    <h1>Payments Admin</h1>
    <label>Admin Password</label>
    <input type="password" id="adminKeyInput" placeholder="Enter admin password">
    <button onclick="checkAdminKey()">Enter</button>
    <div id="gateMsg" style="color:#f87171; margin-top:10px; font-size:13px;"></div>
  </div>

  <div id="mainContent">
    <h1>Payments Admin</h1>

    <div class="card">
      <h2 style="margin-top:0; font-size:16px;">Create New Quotation</h2>
      <label>Client Name</label>
      <input type="text" id="newClientName">
      <label>Client Phone</label>
      <input type="text" id="newClientPhone" placeholder="e.g. 0712345678">
      <label>Project Title</label>
      <input type="text" id="newTitle">
      <label>Total Amount (KES)</label>
      <input type="number" id="newTotal">
      <label>Deposit Percentage</label>
      <input type="number" id="newDepositPercent" value="50">
      <button onclick="createQuotation()">Create Quotation</button>
      <div id="createMsg" style="margin-top:10px; font-size:13px;"></div>
    </div>

    <div class="card">
      <h2 style="margin-top:0; font-size:16px;">All Quotations</h2>
      <table>
        <thead>
          <tr>
            <th>Reference</th>
            <th>Client</th>
            <th>Project</th>
            <th>Total</th>
            <th>Deposit Paid</th>
            <th>Balance Paid</th>
            <th>Stage</th>
          </tr>
        </thead>
        <tbody id="quotationsTable"></tbody>
      </table>
    </div>
  </div>

  <script>
    let adminKey = '';

    function checkAdminKey() {
      adminKey = document.getElementById('adminKeyInput').value;
      loadQuotations();
    }

    async function createQuotation() {
      const msg = document.getElementById('createMsg');
      const payload = {
        admin_key: adminKey,
        client_name: document.getElementById('newClientName').value.trim(),
        client_phone: document.getElementById('newClientPhone').value.trim(),
        title: document.getElementById('newTitle').value.trim(),
        total_amount: parseFloat(document.getElementById('newTotal').value),
        deposit_percent: parseInt(document.getElementById('newDepositPercent').value)
      };
      try {
        const res = await fetch('payments.php?action=create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (data.success) {
          msg.style.color = '#4ade80';
          msg.textContent = 'Created! Reference: ' + data.quotation.reference + ' - send this link to the client: payment-status.html?ref=' + data.quotation.reference;
          document.getElementById('newClientName').value = '';
          document.getElementById('newClientPhone').value = '';
          document.getElementById('newTitle').value = '';
          document.getElementById('newTotal').value = '';
          loadQuotations();
        } else {
          msg.style.color = '#f87171';
          msg.textContent = data.error || 'Could not create quotation.';
        }
      } catch (e) {
        msg.style.color = '#f87171';
        msg.textContent = 'Could not connect to the server. This only works on a live PHP host.';
      }
    }

    async function loadQuotations() {
      const gateMsg = document.getElementById('gateMsg');
      try {
        const res = await fetch('payments.php?action=list&admin_key=' + encodeURIComponent(adminKey));
        const data = await res.json();
        if (!data.success) {
          gateMsg.textContent = data.error || 'Invalid password.';
          return;
        }
        document.getElementById('adminGate').style.display = 'none';
        document.getElementById('mainContent').style.display = 'block';

        const tbody = document.getElementById('quotationsTable');
        tbody.innerHTML = '';
        data.quotations.slice().reverse().forEach(q => {
          const depositPaid = q.payments.some(p => p.type === 'deposit' && p.status === 'completed');
          const balancePaid = q.payments.some(p => p.type === 'balance' && p.status === 'completed');
          const row = document.createElement('tr');
          row.innerHTML = `
            <td><span class="ref-copy" onclick="navigator.clipboard.writeText('${q.reference}')" title="Click to copy">${q.reference}</span></td>
            <td>${q.client_name}<br><small style="color:#94a3b8;">${q.client_phone}</small></td>
            <td>${q.title}</td>
            <td>KES ${Math.round(q.total_amount)}</td>
            <td>${depositPaid ? '&check;' : '-'}</td>
            <td>${balancePaid ? '&check;' : '-'}</td>
            <td><span class="badge">${q.stage}</span></td>
          `;
          tbody.appendChild(row);
        });
      } catch (e) {
        gateMsg.textContent = 'Could not connect to the server. This only works on a live PHP host.';
      }
    }
  </script>
</body>
</html>